rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Allow public read access to all files (for CDN)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow uploads to knowledge base folder (Agent Collective)
    match /knowledge/{market}/{fileName} {
      allow write: if request.resource.size < 50 * 1024 * 1024  // Max 50MB
                   && request.resource.contentType.matches('application/pdf|application/vnd.openxmlformats-officedocument.*');
    }

    // Allow image uploads to Creative Generator uploads folder
    match /uploads/{country}/{fileName} {
      allow write: if request.resource.size < 10 * 1024 * 1024  // Max 10MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Only allow writes from Cloud Functions (via admin SDK) for other paths
    match /{allPaths=**} {
      allow write: if false;
    }
  }
}
