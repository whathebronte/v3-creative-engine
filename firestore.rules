rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // CREATIVE GENERATOR & TEMPLATE STAMPER
    // ========================================================================

    // Jobs collection - Video rendering jobs
    match /jobs/{jobId} {
      // Allow read for everyone (for testing)
      // TODO: Add authentication in Phase 2
      allow read: if true;

      // Allow create for everyone (Cloud Functions use admin SDK which bypasses rules)
      allow create: if true;

      // Allow update/delete only for cloud functions (via admin SDK)
      allow update, delete: if false;
    }

    // Gallery collection - Saved assets
    match /gallery/{galleryId} {
      // Allow read/write for everyone (no auth for now)
      // TODO: Add authentication later
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }

    // Template Stamper Transfers - Asset transfers from Creative Generator
    match /template_stamper_transfers/{transferId} {
      // Allow read for everyone (Template Stamper needs to read transfers)
      allow read: if true;
      // Allow create from Creative Generator
      allow create: if true;
      // Allow update for Template Stamper to mark as processed
      allow update: if true;
      // Allow delete for cleanup
      allow delete: if true;
    }

    // ========================================================================
    // AGENT COLLECTIVE
    // ========================================================================

    // Agent Collective - Market setups (protocols, knowledge files)
    match /agent_markets/{marketId} {
      allow read: if true;
      allow write: if true;
    }

    // Agent Collective - Chat archives
    match /chat_archives/{archiveId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;
    }

    // Agent Collective - Prompt transfers (for analytics)
    match /prompt_transfers/{transferId} {
      allow read: if true;
      allow create: if true;
    }

    // ========================================================================
    // SHORTS BRAIN
    // ========================================================================

    // Shorts Brain - Campaign data
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if true;
    }

    // Shorts Brain - Analysis results
    match /analysis_results/{resultId} {
      allow read: if true;
      allow write: if true;
    }

    // ========================================================================
    // SHORTS INTEL HUB
    // ========================================================================

    // Shorts Intel Hub - Weekly topics and insights
    match /weekly_topics/{topicId} {
      allow read: if true;
      // Only Cloud Functions can write
      allow write: if false;
    }

    // Shorts Intel Hub - Topic embeddings (for vector search)
    match /topic_embeddings/{embeddingId} {
      allow read: if true;
      // Only Cloud Functions can write
      allow write: if false;
    }

    // ========================================================================
    // DEFAULT RULE
    // ========================================================================

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
